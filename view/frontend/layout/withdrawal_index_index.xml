<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <attribute name="class" value="panth-euw-page"/>
        <referenceContainer name="content">
            <block class="Magento\Framework\View\Element\Template"
                   name="panth.euwithdrawal.page"
                   template="Panth_EuWithdrawal::page.phtml"
                   cacheable="false">
                <arguments>
                    <argument name="view_model" xsi:type="object">Panth\EuWithdrawal\ViewModel\Withdrawal</argument>
                </arguments>
                <block class="Magento\Framework\View\Element\Template"
                       name="panth.euwithdrawal.page.fields" as="fields"
                       template="Panth_EuWithdrawal::form/fields.phtml">
                    <arguments>
                        <argument name="view_model" xsi:type="object">Panth\EuWithdrawal\ViewModel\Withdrawal</argument>
                        <argument name="form_id" xsi:type="string">page</argument>
                    </arguments>
                </block>
            </block>
        </referenceContainer>
    </body>
</page>
