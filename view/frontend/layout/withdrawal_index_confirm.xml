<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <attribute name="class" value="panth-euw-page"/>
        <referenceContainer name="content">
            <block class="Magento\Framework\View\Element\Template"
                   name="panth.euwithdrawal.confirm"
                   template="Panth_EuWithdrawal::confirm.phtml"
                   cacheable="false">
                <arguments>
                    <argument name="view_model" xsi:type="object">Panth\EuWithdrawal\ViewModel\Withdrawal</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
