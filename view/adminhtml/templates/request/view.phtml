<?php
/**
 * Admin — withdrawal request detail + status update.
 *
 * @var \Panth\EuWithdrawal\Block\Adminhtml\Request\View $block
 * @var \Magento\Framework\Escaper $escaper
 */
$request = $block->getWithdrawalRequest();
if (!$request) {
    return;
}
$currentStatus = (int)$request->getStatus();
?>
<div class="panth-euw-admin-view">
    <div class="admin__page-section">
        <div class="admin__page-section-title">
            <span class="title"><?= $escaper->escapeHtml(__('Withdrawal Details')) ?></span>
        </div>
        <div class="admin__page-section-content">
            <table class="admin__table-secondary">
                <tbody>
                    <tr>
                        <th><?= $escaper->escapeHtml(__('Proof Reference')) ?></th>
                        <td><?= $escaper->escapeHtml($request->getProofReference()) ?></td>
                    </tr>
                    <tr>
                        <th><?= $escaper->escapeHtml(__('Order')) ?></th>
                        <td>
                            <?php if ($block->getOrderViewUrl()): ?>
                                <a href="<?= $escaper->escapeUrl($block->getOrderViewUrl()) ?>"><?= $escaper->escapeHtml($request->getIncrementId()) ?></a>
                            <?php else: ?>
                                <?= $escaper->escapeHtml($request->getIncrementId()) ?>
                            <?php endif; ?>
                        </td>
                    </tr>
                    <tr>
                        <th><?= $escaper->escapeHtml(__('Customer')) ?></th>
                        <td><?= $escaper->escapeHtml($request->getCustomerName()) ?> (<?= $escaper->escapeHtml($request->getCustomerEmail()) ?>)</td>
                    </tr>
                    <tr>
                        <th><?= $escaper->escapeHtml(__('Requested At')) ?></th>
                        <td><?= $escaper->escapeHtml($block->formatDate2($request->getRequestedAt())) ?></td>
                    </tr>
                    <?php if ($request->getReason()): ?>
                        <tr>
                            <th><?= $escaper->escapeHtml(__('Reason')) ?></th>
                            <td><?= $escaper->escapeHtml($request->getReason()) ?></td>
                        </tr>
                    <?php endif; ?>
                    <tr>
                        <th><?= $escaper->escapeHtml(__('Confirmation Email Sent')) ?></th>
                        <td><?= $request->getConfirmationSent() ? $escaper->escapeHtml(__('Yes')) : $escaper->escapeHtml(__('No')) ?></td>
                    </tr>
                    <tr>
                        <th><?= $escaper->escapeHtml(__('Content Of The Withdrawal')) ?></th>
                        <td><pre style="white-space:pre-wrap;font-family:inherit;margin:0;"><?= $escaper->escapeHtml($request->getWithdrawalContent()) ?></pre></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <form action="<?= $escaper->escapeUrl($block->getSaveUrl()) ?>" method="post">
        <?= $block->getBlockHtml('formkey') ?>
        <input type="hidden" name="request_id" value="<?= (int)$request->getId() ?>"/>
        <div class="admin__page-section">
            <div class="admin__page-section-title">
                <span class="title"><?= $escaper->escapeHtml(__('Manage')) ?></span>
            </div>
            <div class="admin__page-section-content">
                <div class="admin__field">
                    <label class="admin__field-label"><span><?= $escaper->escapeHtml(__('Status')) ?></span></label>
                    <div class="admin__field-control">
                        <select name="status" class="admin__control-select">
                            <?php foreach ($block->getStatusOptions() as $value => $label): ?>
                                <option value="<?= (int)$value ?>" <?= $currentStatus === (int)$value ? 'selected="selected"' : '' ?>>
                                    <?= $escaper->escapeHtml(__($label)) ?>
                                </option>
                            <?php endforeach; ?>
                        </select>
                    </div>
                </div>
                <div class="admin__field">
                    <label class="admin__field-label"><span><?= $escaper->escapeHtml(__('Internal Note')) ?></span></label>
                    <div class="admin__field-control">
                        <textarea name="admin_note" rows="3" class="admin__control-textarea"><?= $escaper->escapeHtml($request->getData('admin_note')) ?></textarea>
                    </div>
                </div>
            </div>
        </div>
        <div class="admin__page-section" style="display:flex;gap:10px;">
            <button type="submit" class="action-primary"><span><?= $escaper->escapeHtml(__('Save')) ?></span></button>
            <a href="<?= $escaper->escapeUrl($block->getBackUrl()) ?>" class="action-secondary"><span><?= $escaper->escapeHtml(__('Back')) ?></span></a>
        </div>
    </form>
</div>
