<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <!-- Batch processor: retry failed confirmation emails + refund-deadline reminders -->
        <job name="panth_euwithdrawal_process_requests"
             instance="Panth\EuWithdrawal\Cron\ProcessRequests"
             method="execute">
            <schedule>*/15 * * * *</schedule>
        </job>
        <!-- Daily anonymous heartbeat (deduped per day) -->
        <job name="panth_euwithdrawal_heartbeat"
             instance="Panth\EuWithdrawal\Cron\SendHeartbeat"
             method="execute">
            <schedule>0 3 * * *</schedule>
        </job>
    </group>
</config>
